#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Pre-commit Quality Checks
# Enforces type safety and test coverage before commits

echo "🔍 Running pre-commit checks..."

# Run TypeScript compilation check
echo "📝 Checking TypeScript compilation..."
npx tsc --noEmit --skipLibCheck || {
  echo "❌ TypeScript compilation failed. Please fix type errors before committing."
  exit 1
}

# Run ESLint with enhanced rules
echo "🔧 Running ESLint with enhanced type safety rules..."
npm run lint || {
  echo "⚠️  ESLint found issues. Please fix linting errors before committing."
  echo "💡 Run 'npm run lint -- --fix' to auto-fix some issues."
  exit 1
}

# Run unit/contract tests (fast, ~15s)
echo "🧪 Running unit and contract tests..."
npm run test:ci || {
  echo "❌ Tests failed. Please fix failing tests before committing."
  echo "💡 Run 'npm test' to see detailed test output."
  exit 1
}

echo "✅ All pre-commit checks passed!"