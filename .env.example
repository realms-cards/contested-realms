# ============================================================================
# Sorcery Client - Environment Variables
# ============================================================================
# Copy this file to .env.local for development:
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-side only.
# ============================================================================

# -----------------------------------
# Core Application
# -----------------------------------
# Node environment: development | production | test
NODE_ENV=development

# Base URL of your Next.js application
NEXTAUTH_URL="http://localhost:3000"

# Secret used by NextAuth to sign/encrypt tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# Public base URL (used for sitemap, robots.txt, meta tags)
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Public app URL (used in client-side links)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------
# Database (PostgreSQL via Prisma)
# -----------------------------------
# For local dev with Docker: see docker-compose.yml
# Example local connection strings (matching docker-compose service):
# DATABASE_URL="postgresql://sorcery:sorcery@localhost:5432/sorcery?schema=public"
# DIRECT_URL="postgresql://sorcery:sorcery@localhost:5432/sorcery?schema=public"
#
# For DigitalOcean Managed Postgres (pooled + direct):
# DATABASE_URL="postgresql://<user>:<pass>@<host>:25061/<db>?sslmode=require"
# DIRECT_URL="postgresql://<user>:<pass>@<host>:25060/<db>?sslmode=require"
#
# For Supabase (pooled + direct):
# DATABASE_URL="postgresql://<user>:<pass>@db.<project>.supabase.co:6543/postgres?sslmode=require"
# DIRECT_URL="postgresql://<user>:<pass>@db.<project>.supabase.co:5432/postgres?sslmode=require"
#
# (Optional) Shadow DB for prisma migrate dev (avoids CREATE DATABASE perms)
# SHADOW_DATABASE_URL="postgresql://<user>:<pass>@<host>:25060/<shadow_db>?sslmode=require"
DATABASE_URL=
DIRECT_URL=
# SHADOW_DATABASE_URL=

# -----------------------------------
# Redis (Socket.IO adapter + state)
# -----------------------------------
# For local dev with Docker Redis service
# REDIS_URL="redis://localhost:6379"

# Disable the Socket.IO Redis adapter for single-instance dev (set to true/1)
# SOCKET_REDIS_DISABLED=true

# Enable Redis-backed state for player, match, and lobby data.
# Required for horizontal scaling with multiple server instances.
# Default: false (local Maps only, single-instance mode)
# REDIS_STATE_ENABLED=false

# -----------------------------------
# Socket.IO Server
# -----------------------------------
# Port for the standalone Socket.IO server (default: 3010)
PORT=3010

# URL the Next.js app uses to reach the socket server
SOCKET_SERVER_URL="http://localhost:3010"

# Require NextAuth-signed JWT in handshake (recommended for production)
# SOCKET_REQUIRE_JWT=false

# Comma-separated origins allowed to connect (CORS)
SOCKET_CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# Socket.IO ping/pong tuning (milliseconds)
# SOCKET_PING_INTERVAL_MS=25000
# SOCKET_PING_TIMEOUT_MS=20000

# Graceful shutdown timeout in milliseconds
# SHUTDOWN_TIMEOUT_MS=10000

# Server instance ID (for multi-instance logging)
# INSTANCE_ID=

# -----------------------------------
# Client WebSocket Config (NEXT_PUBLIC_)
# -----------------------------------
# Point the web app at your Socket.IO server
NEXT_PUBLIC_WS_URL="http://localhost:3010"

# Custom Socket.IO path (default: /socket.io)
# NEXT_PUBLIC_WS_PATH=

# Force transports: 'websocket' is safest behind proxies
# NEXT_PUBLIC_WS_TRANSPORTS=websocket

# HTTP origin for REST-like requests to the Socket.IO server
# NEXT_PUBLIC_WS_HTTP_ORIGIN="http://localhost:3010"

# Reconnection settings
# NEXT_PUBLIC_WS_RECONNECT_ATTEMPTS=10
# NEXT_PUBLIC_WS_RECONNECT_DELAY_MAX=5000
# NEXT_PUBLIC_WS_TIMEOUT_MS=20000

# Cursor sync interval (milliseconds)
# NEXT_PUBLIC_CURSOR_MS=50

# -----------------------------------
# Authentication - Discord OAuth
# -----------------------------------
# Create an app at https://discord.com/developers/applications
# Set redirect URL to: http://localhost:3000/api/auth/callback/discord
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# -----------------------------------
# Authentication - Email (Magic Link)
# -----------------------------------
# SMTP connection URI, e.g. "smtp://user:pass@smtp.example.com:587"
# EMAIL_SERVER=
# Sender address, e.g. "Sorcery <noreply@example.com>"
# EMAIL_FROM=

# -----------------------------------
# Authentication - WebAuthn / Passkeys
# -----------------------------------
# Relying Party ID must match your domain (no scheme). Use "localhost" for dev.
# WEB_AUTHN_RP_ID="localhost"
# Display name shown in authenticator UIs
# WEB_AUTHN_RP_NAME="Sorcery Client"
# Origin(s) allowed during attestation/assertion
# WEB_AUTHN_ORIGIN="http://localhost:3000"

# -----------------------------------
# Authentication - Test/Dev Helpers
# -----------------------------------
# Enable test 2FA bypass for development
ENABLE_TEST_2FA=true
TEST_2FA_CODE=424242

# Debug token logging (NEVER enable in production)
# NEXTAUTH_DEBUG_TOKENS=false

# -----------------------------------
# Feature Flags
# -----------------------------------
# CPU bot matches (1/true to enable)
NEXT_PUBLIC_CPU_BOTS_ENABLED=1

# Video overlay in game (experimental)
NEXT_PUBLIC_FEATURE_SEAT_VIDEO=false

# Tournament system
NEXT_PUBLIC_FEATURE_TOURNAMENTS=false

# Audio-only mode for matches
NEXT_PUBLIC_FEATURE_AUDIO_ONLY=false

# Undo support
NEXT_PUBLIC_FEATURE_UNDO=true

# Teaching mode (guided play for new players)
NEXT_PUBLIC_FEATURE_TEACHING_MODE=false

# Interactive tutorial
NEXT_PUBLIC_FEATURE_TUTORIAL_MODE=false

# Curiosa deck import (URL/TTS format)
# NEXT_PUBLIC_ENABLE_CURIOSA_IMPORT=false

# Plain text deck import
# NEXT_PUBLIC_ENABLE_TEXT_IMPORT=false

# Physics debug visualization (dev only)
# NEXT_PUBLIC_DEBUG_PHYSICS=false

# -----------------------------------
# Rules Engine
# -----------------------------------
# Enforcement mode:
#   off      -> helpers only (no strict gating)
#   bot_only -> strict for CPU bots, helpers for humans
#   all      -> strict for everyone
RULES_ENFORCE_MODE=off

# Enable helpers: turn-start untap, spend accounting, cost auto-apply
RULES_HELPERS_ENABLED=true

# Enable interaction enforcement (combat/magic guides)
# INTERACTION_ENFORCEMENT_ENABLED=false

# -----------------------------------
# CPU Bot / AI
# -----------------------------------
# Bot AI engine mode
# CPU_AI_ENGINE_MODE=

# Bot deck file path
# CPU_BOT_DECK_FILE=

# Bot parameters file path
# CPU_AI_PARAMS_PATH=

# Debug logging for bot decisions
# DEBUG_LOGS=false

# -----------------------------------
# WebRTC ICE/TURN
# -----------------------------------
# TURN server for peer-to-peer video/audio
# For dev, use the local TURN service from docker-compose
NEXT_PUBLIC_TURN_URL=turn:localhost:3478
NEXT_PUBLIC_TURN_USERNAME=devuser
NEXT_PUBLIC_TURN_CREDENTIAL=devpass

# -----------------------------------
# Texture / WebGL Optimization
# -----------------------------------
# Cache TTL: how long unused textures stay in memory (default: 30000ms)
# WARNING: Values < 20s cause poor HMR performance in dev
# NEXT_PUBLIC_TEXTURE_CACHE_TTL_MS=30000

# Max cached textures (default: 150). Increase for cube drafts (300+ cards).
# WARNING: Values < 100 cause constant texture reloading
# NEXT_PUBLIC_TEXTURE_CACHE_MAX_SIZE=150

# KTX2 retry delay after load failure (default: 60000ms)
# NEXT_PUBLIC_KTX2_RETRY_MS=60000

# KTX2 transcoder path (default: /ktx2/)
# NEXT_PUBLIC_KTX2_TRANSCODER_PATH="/ktx2/"

# KTX2 asset version (cache busting)
# NEXT_PUBLIC_KTX2_VERSION=1

# Max anisotropy for texture filtering
# NEXT_PUBLIC_MAX_ANISOTROPY=

# Texture origin override
# NEXT_PUBLIC_TEXTURE_ORIGIN=

# Use a shared global WebGL canvas (experimental)
# NEXT_PUBLIC_USE_GLOBAL_CANVAS=false

# -----------------------------------
# CDN / Asset Delivery (optional)
# -----------------------------------
# If set, /api/images and /api/assets redirect to this CDN origin
# ASSET_CDN_ORIGIN="https://cdn.example.com"

# Force CDN redirect even in development
# FORCE_TEXTURE_CDN=false

# Admin CDN origin for asset management
# ADMIN_CDN_ORIGIN=

# -----------------------------------
# Discord Bot Integration
# -----------------------------------
# Enable Discord bot features (challenges, voice, linking)
# DISCORD_BOT_ENABLED=false

# Bot token from Discord Developer Portal
# DISCORD_BOT_TOKEN=

# Guild ID for guild-specific slash commands (faster updates in dev)
# DISCORD_GUILD_ID=

# Shared secret for bot <-> API authentication (generate a random string)
# REALMS_BOT_SECRET=

# -----------------------------------
# Bug Reporting (GitHub Issues)
# -----------------------------------
# GitHub PAT with repo scope for creating issues
# Create at: https://github.com/settings/tokens
# GITHUB_BUG_REPORT_TOKEN=

# -----------------------------------
# SOATC League Integration
# -----------------------------------
# Enable SOATC league features (tournament detection, result export)
# SOATC_LEAGUE_ENABLED=false
# NEXT_PUBLIC_SOATC_ENABLED=false

# API token from ranking.sorcerersatthecore.com
# SORCERERS_AT_THE_CORE_APITOKEN=

# HMAC shared secret for request signing
# SOATC_SHARED_SECRET=

# Sorcerers Summit API key
# SORCERERS_SUMMIT_API_KEY=

# -----------------------------------
# Challonge Tournament Brackets
# -----------------------------------
# CHALLONGE_APIKEY=
# CHALLONGE_CLIENTID=
# CHALLONGE_SECRET=

# -----------------------------------
# Admin & Monitoring
# -----------------------------------
# Comma-separated user IDs with admin access
# ADMIN_USER_IDS=

# Socket server health check URL
# ADMIN_SOCKET_HEALTH_URL=http://127.0.0.1:3010/healthz

# IP allowlist for admin routes (comma-separated)
# ADMIN_IP_ACCESSLIST=127.0.0.1

# Comma-separated user IDs allowed to spectate/commentate
# COMMENTATOR_IDS=

# -----------------------------------
# Frontend Lockdown (HTTP Basic Auth)
# -----------------------------------
# Protect the entire site behind basic auth (useful for private testing)
# BASIC_AUTH_ENABLED=false
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASSWORD=changeme

# Full site lockdown mode
# LOCKDOWN_ENABLED=false

# -----------------------------------
# Match Lifecycle
# -----------------------------------
# Stale match auto-close thresholds (milliseconds)
# Human matches default to 7 days, bot matches to 2 days
# STALE_MATCH_HUMAN_MS=604800000
# STALE_MATCH_BOT_MS=172800000

# Waiting match timeout (ms) before auto-cancel
# STALE_MATCH_WAITING_MS=

# Inactive match cleanup delay (ms)
# INACTIVE_MATCH_CLEANUP_MS=

# Match session TTL (seconds)
# MATCH_SESSION_TTL_SEC=

# Match cleanup delay after completion (ms)
# MATCH_CLEANUP_DELAY_MS=

# -----------------------------------
# State Persistence (Write-Behind)
# -----------------------------------
# Strategy: write_behind (batched) or write_through (immediate)
# PERSIST_STRATEGY=write_behind

# Flush interval for batched writes (ms, default: 3000)
# PERSIST_FLUSH_INTERVAL_MS=3000

# Max wait before forcing a flush (ms)
# PERSIST_MAX_WAIT_MS=

# Persistence timeout (ms)
# PERSIST_TIMEOUT_MS=

# Action batch size for bulk writes (default: 200)
# PERSIST_ACTION_BATCH_SIZE=200

# -----------------------------------
# Replay Retention
# -----------------------------------
# Replays are kept indefinitely by default.
# Set to enable automatic cleanup of old replays.
# REPLAY_RETENTION_DAYS=14

# -----------------------------------
# Rate Limiting
# -----------------------------------
# Chat: capacity / refill count / interval (ms)
# RATE_LIMIT_CHAT_CAPACITY=5
# RATE_LIMIT_CHAT_REFILL=1
# RATE_LIMIT_CHAT_INTERVAL=10000

# Cursor updates
# RATE_LIMIT_CURSOR_CAPACITY=30
# RATE_LIMIT_CURSOR_REFILL=10
# RATE_LIMIT_CURSOR_INTERVAL=1000

# Game messages
# RATE_LIMIT_MESSAGE_CAPACITY=50
# RATE_LIMIT_MESSAGE_REFILL=10
# RATE_LIMIT_MESSAGE_INTERVAL=10000

# Connections per IP
# RATE_LIMIT_CONN_CAPACITY=20
# RATE_LIMIT_CONN_REFILL=5
# RATE_LIMIT_CONN_INTERVAL=30000

# -----------------------------------
# Cron / Scheduled Tasks
# -----------------------------------
# Secret for authenticating cron job requests
# CRON_SECRET=

# -----------------------------------
# Internal API
# -----------------------------------
# Shared key for internal service-to-service calls
# INTERNAL_API_KEY=

# -----------------------------------
# Anthropic (AI features, optional)
# -----------------------------------
# ANTHROPIC_API_KEY=

# -----------------------------------
# Deck Editor
# -----------------------------------
# Concurrent card lookups in deck editor (default: 4)
# NEXT_PUBLIC_EDITOR_LOOKUP_CONCURRENCY=4

# -----------------------------------
# Debug (dev only)
# -----------------------------------
# Match IDs to enable detailed state debugging
# MATCH_STATE_DEBUG_IDS=

# Enable build bundle analysis
# ANALYZE=false

# Run integration tests (used in CI)
# RUN_INTEGRATION_TESTS=false

# Test tokens for automated testing
# TEST_USER_TOKEN=
# TEST_ADMIN_TOKEN=
