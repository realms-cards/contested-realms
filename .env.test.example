# Test Environment Variables
# Copy this file to .env.test and update values

# Database (Test Container)
DATABASE_URL="postgresql://sorcery_test:test_password@localhost:5433/sorcery_test"
DIRECT_URL="postgresql://sorcery_test:test_password@localhost:5433/sorcery_test"
SHADOW_DATABASE_URL="postgresql://sorcery_test:test_password@localhost:5433/sorcery_test_shadow"

# Socket Server (Test Container)
SOCKET_SERVER_URL="http://localhost:3010"
NEXT_PUBLIC_WS_URL="http://localhost:3010"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Test Mode
NODE_ENV="test"
RUN_INTEGRATION_TESTS="true"

# Authentication (Test Tokens)
TEST_USER_TOKEN="test_token_123"
