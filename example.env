# This is the URL of your application
NEXTAUTH_URL="http://localhost:3000"

# Email magic link authentication
# Provide SMTP connection URI (username + password required),
# e.g. "smtp://myuser:mypassword@smtp.mailtrap.io:2525"
EMAIL_SERVER=
# Sender address used in verification emails, e.g. "Sorcery Client <noreply@example.com>"
EMAIL_FROM=

# TestAuth
TEST_2FA_CODE=424242
ENABLE_TEST_2FA=true

NEXT_PUBLIC_FEATURE_SEAT_VIDEO=false
NEXT_PUBLIC_FEATURE_TOURNAMENTS=false
NEXT_PUBLIC_FEATURE_AUDIO_ONLY=false
NEXT_PUBLIC_FEATURE_UNDO=true

# Server
PORT=3010

# CPU bots feature flag
# 1/true to enable, 0/false to disable
NEXT_PUBLIC_CPU_BOTS_ENABLED=1

# Rules enforcement mode
# off      -> helpers only (no strict gating for anyone)
# bot_only -> strictly enforce rules for CPU bots only, humans get helpers but are not blocked
# all      -> strictly enforce rules for both humans and bots
RULES_ENFORCE_MODE=off

# Enable helper behavior (applied even when enforcement is off)
# true  -> enable helpers like turn-start untap, per-turn spend accounting, cost auto-apply
# false -> disable helper auto-adjustments
RULES_HELPERS_ENABLED=true

# -----------------------------------
# Deck Import feature flags (frontend + API)
# -----------------------------------
# Enable Curiosa URL/TTS import panel and API route
# NEXT_PUBLIC_ENABLE_CURIOSA_IMPORT=false
# Enable plain text deck import panel and API route
# NEXT_PUBLIC_ENABLE_TEXT_IMPORT=false

# -----------------------------------
# Database (PostgreSQL via Prisma)
# -----------------------------------
# For local dev with Docker: see docker-compose.yml
# Example local connection strings (matching docker-compose service):
# DATABASE_URL="postgresql://sorcery:sorcery@localhost:5432/sorcery?schema=public"
# DIRECT_URL="postgresql://sorcery:sorcery@localhost:5432/sorcery?schema=public"
#
# For DigitalOcean Managed Postgres (pooled + direct):
# DATABASE_URL="postgresql://<user>:<pass>@<host>:25061/<db>?sslmode=require" # use pooled endpoint
# DIRECT_URL="postgresql://<user>:<pass>@<host>:25060/<db>?sslmode=require"  # primary endpoint for migrations
# (Optional) SHADOW_DATABASE_URL for prisma migrate dev (use a separate DB; avoids CREATE DATABASE perms)
# SHADOW_DATABASE_URL="postgresql://<user>:<pass>@<host>:25060/<shadow_db>?sslmode=require"
#
# For Supabase (pooled + direct):
# DATABASE_URL="postgresql://<user>:<pass>@db.<project>.supabase.co:6543/postgres?sslmode=require" # pooled
# DIRECT_URL="postgresql://<user>:<pass>@db.<project>.supabase.co:5432/postgres?sslmode=require"   # direct
# SHADOW_DATABASE_URL="postgresql://<user>:<pass>@db.<project>.supabase.co:5432/<shadow_db>?sslmode=require"
#
# Uncomment and set for your environment
DATABASE_URL=
DIRECT_URL=
SHADOW_DATABASE_URL=

# -----------------------------------
# Redis (Socket.IO adapter + caching)
# -----------------------------------
# For local dev with Docker Redis service
# REDIS_URL="redis://localhost:6379"
# To disable the Socket.IO Redis adapter (single-instance dev): set to true/1
# SOCKET_REDIS_DISABLED=

# -----------------------------------
# Horizontal Scaling (Multi-instance)
# -----------------------------------
# Enable Redis-backed state for player, match, and lobby data.
# When enabled, state is stored in Redis as authoritative source with local caching.
# Required for horizontal scaling with multiple server instances behind a load balancer.
# Features when enabled:
#   - Player state in Redis (cross-instance player lookup)
#   - Match leader heartbeat (15s TTL with 5s refresh)
#   - Player rooms for cross-instance messaging
#   - 30s disconnect grace period
# Default: false (local Maps only, single-instance mode)
# REDIS_STATE_ENABLED=true

# Graceful shutdown timeout in milliseconds
# SHUTDOWN_TIMEOUT_MS=10000

# -----------------------------------
# Client (Next.js) WebSocket config
# -----------------------------------
# Point the web app at your Socket.IO server. In dev, this is usually:
# NEXT_PUBLIC_WS_URL="http://localhost:3010"
# If you run via Caddy inside docker-compose, it is also http://localhost:3010 (Caddy front).
# Custom Socket.IO path if you change it from the default '/socket.io'
# NEXT_PUBLIC_WS_PATH=
# Force transports if your proxy blocks polling; 'websocket' is often safest behind proxies
# NEXT_PUBLIC_WS_TRANSPORTS=websocket
# HTTP origin for REST-like requests to the Socket.IO server (e.g., /players/available)
# If unset, client code may derive it from NEXT_PUBLIC_WS_URL by replacing ws->http.
# Set explicitly if your WS URL uses wss/https or a different host.
# NEXT_PUBLIC_WS_HTTP_ORIGIN="http://localhost:3010"

# -----------------------------------
# WebRTC ICE/TURN (Dev)
# -----------------------------------
# Point the client to the local TURN service from docker-compose.dev.single.yml
# For dev we use non-TLS TURN on 3478
NEXT_PUBLIC_TURN_URL=turn:localhost:3478
NEXT_PUBLIC_TURN_USERNAME=devuser
NEXT_PUBLIC_TURN_CREDENTIAL=devpass

# Optional: Self-host KTX2 transcoder assets under public/ktx2/
# Provide a custom path or leave unset to default to /ktx2/
# NEXT_PUBLIC_KTX2_TRANSCODER_PATH="/ktx2/"

# Texture cache optimization (to prevent WebGL context loss from memory exhaustion)
# Cache TTL: how long to keep unused textures in memory (default: 30000ms = 30s)
# WARNING: Values < 20s cause poor performance in dev mode due to Hot Module Reload
# NEXT_PUBLIC_TEXTURE_CACHE_TTL_MS=30000
# Max cache size: maximum number of textures to keep (default: 150)
# WARNING: Values < 100 cause constant texture reloading
# NEXT_PUBLIC_TEXTURE_CACHE_MAX_SIZE=150
# KTX2 retry delay after load failure (default: 60000ms = 60s)
# NEXT_PUBLIC_KTX2_RETRY_MS=60000

# -----------------------------------
# WebAuthn / Passkeys
# -----------------------------------
# Relying Party (RP) ID must match your domain (no scheme). In dev use localhost.
# WEB_AUTHN_RP_ID="localhost"
# Display name for RP shown in authenticator UIs
# WEB_AUTHN_RP_NAME="Realms Cards"
# Origin(s) allowed during attestation/assertion
# WEB_AUTHN_ORIGIN="http://localhost:3000"

# -----------------------------------
# CDN Redirect for images/assets (optional)
# -----------------------------------
# If set, /api/images and /api/assets will 308-redirect permanently to this origin
# and prefer .webp for raster assets (KTX2 when requested). Ensure your CDN serves
# with CORS and long-lived cache headers.
# ASSET_CDN_ORIGIN="https://cdn.realms.cards"
#
# Force CDN redirect even in development mode (useful when local images are incomplete)
# FORCE_TEXTURE_CDN=true

# -----------------------------------
# Socket.IO server
# -----------------------------------
# Require NextAuth-signed JWT in handshake (recommended for production)
# SOCKET_REQUIRE_JWT=true

# -----------------------------------
# Server Socket.IO CORS (comma-separated origins)
# -----------------------------------
# Allow the web client origins to connect to the WS server
# SOCKET_CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# -----------------------------------
# Frontend lockdown (Vercel Basic Auth)
# -----------------------------------
# Enable to protect the entire Next.js site behind HTTP Basic Auth (middleware.ts)
# Set BASIC_AUTH_PASSWORD (and optionally BASIC_AUTH_USER). Useful for private alpha.
# BASIC_AUTH_ENABLED=false
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASSWORD=changeme

# -----------------------------------
# Replay Retention
# -----------------------------------
# Replay retention pruner is DISABLED by default - replays are kept indefinitely.
# To enable automatic cleanup of old replays, uncomment the retention pruner
# in server/index.ts and set the number of days to keep replays:
# REPLAY_RETENTION_DAYS=14

# -----------------------------------
# Discord Bot Integration
# -----------------------------------
# Enable Discord bot features (match challenges, voice channels, account linking)
# DISCORD_BOT_ENABLED=true
# Bot token from Discord Developer Portal (Bot > Token)
# DISCORD_BOT_TOKEN=
# Application ID (same as OAuth client ID, used for command registration)
# DISCORD_CLIENT_ID=
# Your Discord server ID (for guild-specific commands - faster updates during dev)
# DISCORD_GUILD_ID=
# Shared secret for bot <-> API authentication (generate a random string)
# REALMS_BOT_SECRET=

# -----------------------------------
# Bug Report (GitHub Issues)
# -----------------------------------
# GitHub Personal Access Token with repo scope for creating issues
# Create at: https://github.com/settings/tokens
# Required scopes: repo (or public_repo for public repos only)
# GITHUB_BUG_REPORT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Note: Screenshots are uploaded to realms-cards/snapshots repo
# Make sure to create this repo and give the token write access

# -----------------------------------
# SOATC League Integration
# -----------------------------------
# Enable SOATC league features (tournament detection, result export)
# SOATC_LEAGUE_ENABLED=true
# Client-side flag (must mirror SOATC_LEAGUE_ENABLED to prevent 404 requests)
# NEXT_PUBLIC_SOATC_ENABLED=true
# API token from ranking.sorcerersatthecore.com (Settings > API Tokens)
# SORCERERS_AT_THE_CORE_APITOKEN=
# Shared secret for HMAC signing (optional for Phase 1, required for Phase 2)
# SOATC_SHARED_SECRET=
