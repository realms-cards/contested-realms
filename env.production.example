# Production environment variables for Socket.IO server on Droplet
# Copy to .env.production and adjust secrets/URLs

# ============================================
# SECURITY: Generate strong passwords!
# openssl rand -base64 32
# ============================================

# Redis Password (REQUIRED for production)
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
# Redis connection string - password is passed separately via REDIS_PASSWORD env var
# Do NOT embed password in URL to avoid auth parsing issues
REDIS_URL=redis://redis:6379

# NextAuth shared secret (must match frontend on Vercel)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://realms.cards

# Managed Postgres
# Use pooled DATABASE_URL for app and DIRECT_URL to primary for migrations.
# DigitalOcean Managed Postgres typically requires `sslmode=require`.
# Example (Managed):
# DATABASE_URL="postgresql://<user>:<pass>@<pool-host>:<port>/<db>?sslmode=require&schema=public"
# DIRECT_URL="postgresql://<user>:<pass>@<primary-host>:5432/<db>?sslmode=require&schema=public"
DATABASE_URL=
DIRECT_URL=
SHADOW_DATABASE_URL=

# WebAuthn
WEB_AUTHN_ORIGIN=https://realms.cards
WEB_AUTHN_RP_ID=realms.cards

# Socket auth hardening
SOCKET_REQUIRE_JWT=true
# Frontend origins allowed to connect to ws.realms.cards
SOCKET_CORS_ORIGIN=https://realms.cards,https://*.vercel.app

# Server behavior
PORT=3010
CPU_BOTS_ENABLED=0
RULES_ENFORCE_MODE=off
RULES_HELPERS_ENABLED=true

# Logging/shutdown
SHUTDOWN_TIMEOUT_MS=5000

# Redis Adapter (for horizontal scaling)
ENABLE_REDIS_ADAPTER=true

# Persistence Strategy
PERSIST_STRATEGY=redis_writebehind
PERSIST_FLUSH_INTERVAL_MS=3000
PERSIST_MAX_WAIT_MS=2000
PERSIST_TIMEOUT_MS=2000
PERSIST_ACTION_BATCH_SIZE=200
MATCH_SESSION_TTL_SEC=86400

# Socket.IO Tuning
SOCKET_PING_INTERVAL_MS=15000
SOCKET_PING_TIMEOUT_MS=30000
