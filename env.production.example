# Production environment variables for Socket.IO server on Droplet
# Copy to .env.production and adjust secrets/URLs

# NextAuth shared secret (must match frontend on Vercel)
NEXTAUTH_SECRET=

# Managed Postgres
# Use pooled DATABASE_URL for app and DIRECT_URL to primary for migrations.
# DigitalOcean Managed Postgres typically requires `sslmode=require`.
# Example (Managed):
# DATABASE_URL="postgresql://<user>:<pass>@<pool-host>:<port>/<db>?sslmode=require&schema=public"
# DIRECT_URL="postgresql://<user>:<pass>@<primary-host>:5432/<db>?sslmode=require&schema=public"
DATABASE_URL=
DIRECT_URL=

# Redis (Managed or self-hosted)
# If using self-hosted Redis in docker-compose.prod.yml, keep this default (service DNS name inside Compose network):
REDIS_URL=redis://redis:6379
# If using Managed Redis, override with the managed connection string, e.g.:
# REDIS_URL="redis://default:<password>@<host>:25061?ssl=true"

# Socket auth hardening
SOCKET_REQUIRE_JWT=true
# Frontend origins allowed to connect to ws.realms.cards
SOCKET_CORS_ORIGIN=https://realms.cards,https://*.vercel.app

# Server behavior
PORT=3010
CPU_BOTS_ENABLED=0
RULES_ENFORCE_MODE=off
RULES_HELPERS_ENABLED=true

# Logging/shutdown
SHUTDOWN_TIMEOUT_MS=5000
