{
  "name": "contested-realms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "npm run lint",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "server": "node server/index.js",
    "lint": "eslint",
    "test": "vitest run --config vitest.config.mts --configLoader runner",
    "test:watch": "vitest --config vitest.config.mts --configLoader runner",
    "validate:cards": "node scripts/validate-cards.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push",
    "ingest:cards": "node scripts/ingest-cards.js",
    "seed:packs": "node scripts/seed-pack-config.js",
    "assets:compress": "node scripts/compress-ktx2.js",
    "assets:compress:out": "node scripts/compress-ktx2.js --input data --outDir data-ktx2",
    "assets:compress:etc1s": "node scripts/compress-ktx2.js --format etc1s"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@prisma/client": "^6.14.0",
    "@react-spring/three": "^10.0.2",
    "@react-three/drei": "^10.7.3",
    "@react-three/fiber": "^9.3.0",
    "@react-three/rapier": "^2.1.0",
    "axios": "^1.11.0",
    "boardgame.io": "^0.50.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^10.1.1",
    "lucide-react": "^0.541.0",
    "next": "15.5.0",
    "next-auth": "^4.24.11",
    "prisma": "^6.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.3.1",
    "three": "^0.179.1",
    "zod": "^4.0.17",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
