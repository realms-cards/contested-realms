# Discord Bot Configuration
DISCORD_BOT_TOKEN=           # Bot token from Discord Developer Portal
DISCORD_CLIENT_ID=           # Application ID (same as OAuth client ID)
DISCORD_GUILD_ID=            # Your server ID for guild-specific commands

# Realms.cards API
REALMS_API_URL=http://localhost:3001
REALMS_BOT_SECRET=           # Shared secret for bot <-> API auth

# Redis (for distributed locking - ensures single bot leader)
REDIS_URL=redis://localhost:6379

# Socket.IO server
SOCKET_URL=http://localhost:3001

# Logging
LOG_LEVEL=info
