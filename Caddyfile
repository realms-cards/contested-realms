:3010 {
    log
    encode zstd gzip
    header {
        -Server
    }
    # Keep Socket.IO on a single upstream until sticky sessions are configured.
    reverse_proxy {
        to server1:3010
        health_uri /healthz
        transport http {
            read_timeout 3m
            write_timeout 3m
        }
        flush_interval -1
    }
}
