// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// Enums for consistency with Sorcery rarities and finishes
enum Rarity {
  Ordinary
  Exceptional
  Elite
  Unique
}

enum Finish {
  Standard
  Foil
}

model Set {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  releasedAt  DateTime?

  cardMeta    CardSetMetadata[]
  variants    Variant[]
  packConfig  PackConfig?
  deckCards   DeckCard[] @relation("DeckCardSet")
  cubeCards   CubeCard[] @relation("CubeCardSet")

  @@index([name])
}

model Card {
  id         Int       @id @default(autoincrement())
  name       String
  elements   String?
  subTypes   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  meta       CardSetMetadata[]
  variants   Variant[]
  deckCards  DeckCard[]
  cubeCards  CubeCard[]
  evaluation CardEvaluation?

  @@index([name])
}

// Per-set card metadata (rarity, rules, stats)
model CardSetMetadata {
  id         Int      @id @default(autoincrement())
  cardId     Int
  setId      Int
  rarity     Rarity
  type       String
  rulesText  String?
  cost       Int?
  attack     Int?
  defence    Int?
  life       Int?
  thresholds Json?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  set  Set  @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([cardId, setId])
  @@index([setId, rarity])
}

// Concrete printings/variants (with slug, product, finish, artist)
model Variant {
  id            Int      @id @default(autoincrement())
  cardId        Int
  setId         Int
  slug          String   @unique
  finish        Finish
  product       String
  artist        String?
  flavorText    String?
  typeText      String?
  imageBasename String?  // e.g. apprentice_wizard_b_f (for local image mapping)

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  set  Set  @relation(fields: [setId], references: [id], onDelete: Cascade)
  deckCards DeckCard[] @relation("DeckCardVariant")
  cubeCards CubeCard[] @relation("CubeCardVariant")

  @@index([setId])
  @@index([cardId])
}

// Booster configuration per set
model PackConfig {
  id                     Int     @id @default(autoincrement())
  setId                  Int     @unique
  ordinaryCount          Int
  exceptionalCount       Int
  eliteOrUniqueCount     Int
  uniqueChance           Float   // 0..1 chance that the top rarity slot is Unique instead of Elite
  siteOrAvatarCount      Int     @default(0) // Alpha has 1, Beta 0
  foilChance             Float?  // Probability a foil replaces an ordinary slot (if applicable)
  foilUniqueWeight       Int     @default(1)
  foilEliteWeight        Int     @default(3)
  foilExceptionalWeight  Int     @default(6)
  foilOrdinaryWeight     Int     @default(7)
  foilReplacesOrdinary   Boolean @default(true)

  set Set @relation(fields: [setId], references: [id], onDelete: Cascade)
}

// Decks for users
model Deck {
  id        String   @id @default(cuid())
  name      String
  format    String   @default("Constructed")
  isPublic  Boolean  @default(false)
  imported  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards DeckCard[]

  @@index([userId])
  @@index([isPublic, createdAt])
}

model DeckCard {
  id        Int     @id @default(autoincrement())
  deckId    String
  cardId    Int
  setId     Int?
  variantId Int?
  zone      String  // Spellbook | Atlas | Sideboard
  count     Int

  deck    Deck    @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  set     Set?    @relation("DeckCardSet", fields: [setId], references: [id])
  variant Variant? @relation("DeckCardVariant", fields: [variantId], references: [id])

  @@index([deckId])
  @@index([cardId])
}

// Cubes are draftable card pools managed by users
model Cube {
  id        String   @id @default(cuid())
  name      String
  description String? @db.Text
  isPublic  Boolean  @default(false)
  imported  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards CubeCard[]

  @@index([userId])
  @@index([isPublic, createdAt])
}

model CubeCard {
  id        Int     @id @default(autoincrement())
  cubeId    String
  cardId    Int
  setId     Int?
  variantId Int?
  count     Int

  cube    Cube    @relation(fields: [cubeId], references: [id], onDelete: Cascade)
  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  set     Set?    @relation("CubeCardSet", fields: [setId], references: [id])
  variant Variant? @relation("CubeCardVariant", fields: [variantId], references: [id])

  @@index([cubeId])
  @@index([cardId])
}

// Auth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String? // From Discord
  isPro         Boolean   @default(false)
  stats         String? // Stored as a stringified JSON object
  shortId       String?   @unique
  presenceHidden Boolean  @default(false)

  accounts              Account[]
  sessions              Session[]
  decks                 Deck[]
  cubes                 Cube[]
  createdTournaments    Tournament[]
  tournamentRegistrations TournamentRegistration[]
  standings             PlayerStanding[]
  leaderboardEntries    LeaderboardEntry[]
  tournamentStatistics  TournamentStatistics[] @relation("TournamentPlayerStats")
  wonMatches            MatchResult[] @relation("MatchWinner")
  lostMatches           MatchResult[] @relation("MatchLoser")
  draftParticipations   DraftParticipant[]
  passkeys              PasskeyCredential[]
  friendshipsOwned      Friendship[] @relation("FriendshipOwner")
  friendshipsTargeted   Friendship[] @relation("FriendshipTarget")
  tournamentInvitations TournamentInvitation[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Tournament system models
enum TournamentFormat {
  sealed
  draft
  constructed
}

enum TournamentStatus {
  registering
  preparing
  active
  completed
  cancelled
}

enum PreparationStatus {
  notStarted
  inProgress
  completed
}

enum RoundStatus {
  pending
  active
  completed
}

enum MatchStatus {
  pending
  active
  completed
  cancelled
}

model Tournament {
  id                String            @id @default(cuid())
  name              String
  creatorId         String            // Tournament creator/host
  format            TournamentFormat
  status            TournamentStatus  @default(registering)
  maxPlayers        Int
  isPrivate         Boolean           @default(false) // Private tournaments require invitation
  settings          Json              // Tournament settings (format-specific configuration)
  featureFlags      Json?             // Tournament-specific feature toggles
  startedAt         DateTime?         // When preparation phase began
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  completedAt       DateTime?         // When tournament was completed

  creator           User              @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  registrations     TournamentRegistration[]
  standings         PlayerStanding[]
  rounds            TournamentRound[]
  matches           Match[]
  statistics        TournamentStatistics[] @relation("TournamentStatistics")
  draftSessions     DraftSession[]
  invitations       TournamentInvitation[]

  @@index([status])
  @@index([createdAt])
  @@index([creatorId])
  @@index([isPrivate])
}

model TournamentRegistration {
  id                String            @id @default(cuid())
  tournamentId      String
  playerId          String
  registeredAt      DateTime          @default(now())
  preparationStatus PreparationStatus @default(notStarted)
  deckSubmitted     Boolean           @default(false)
  preparationData   Json?             // Format-specific preparation data

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player       User       @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
}

model PlayerStanding {
  id                           String     @id @default(cuid())
  tournamentId                 String
  playerId                     String
  displayName                  String
  wins                         Int        @default(0)
  losses                       Int        @default(0)
  draws                        Int        @default(0)
  matchPoints                  Int        @default(0)
  gameWinPercentage            Float      @default(0.0)
  opponentMatchWinPercentage   Float      @default(0.0)
  isEliminated                 Boolean    @default(false)
  currentMatchId               String?
  updatedAt                    DateTime   @updatedAt

  tournament                   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player                       User       @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([matchPoints])
}

model TournamentRound {
  id           String      @id @default(cuid())
  tournamentId String
  roundNumber  Int
  status       RoundStatus @default(pending)
  startedAt    DateTime?
  completedAt  DateTime?
  pairingData  Json?       // Swiss pairing information

  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches      Match[]

  @@unique([tournamentId, roundNumber])
  @@index([tournamentId])
}

model Match {
  id           String      @id @default(cuid())
  tournamentId String?
  roundId      String?
  status       MatchStatus @default(pending)
  players      Json        // Array of player IDs and info
  results      Json?       // Match results and game scores
  playerDecks  Json?       // Submitted decklists per player (constructed/sealed/draft)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())

  tournament   Tournament?      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        TournamentRound? @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@index([roundId])
  @@index([status])
}

model TournamentStatistics {
  id            String     @id @default(cuid())
  tournamentId  String
  playerId      String
  wins          Int        @default(0)
  losses        Int        @default(0)
  draws         Int        @default(0)
  matchPoints   Int        @default(0)
  tiebreakers   Json       // Tiebreaker calculations
  finalRanking  Int?       // Final tournament position
  tournament    Tournament @relation("TournamentStatistics", fields: [tournamentId], references: [id], onDelete: Cascade)
  player        User       @relation("TournamentPlayerStats", fields: [playerId], references: [id], onDelete: Cascade)
  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([matchPoints])
}

// Global leaderboard system
enum GameFormat {
  constructed
  sealed
  draft
}

enum TimeFrame {
  all_time
  monthly
  weekly
}

model LeaderboardEntry {
  id           String     @id @default(cuid())
  playerId     String
  displayName  String
  format       GameFormat
  timeFrame    TimeFrame
  wins         Int        @default(0)
  losses       Int        @default(0)
  draws        Int        @default(0)
  winRate      Float      @default(0.0)
  rating       Int        @default(1200)  // ELO-style rating
  rank         Int        @default(0)
  tournamentWins Int      @default(0)
  lastActive   DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  player       User       @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, format, timeFrame])
  @@index([format, timeFrame, rating])
  @@index([format, timeFrame, winRate])
  @@index([rank])
}

// Online match persistence for real-time games (non-tournament quick play)
enum OnlineMatchStatus {
  waiting
  deck_construction
  in_progress
  completed
  cancelled
  ended
}

model OnlineMatchSession {
  id           String            @id @default(cuid())
  lobbyId      String?
  lobbyName    String?
  playerIds    String[]          // Array of player IDs participating in the match
  status       OnlineMatchStatus @default(waiting)
  seed         String
  turn         String?
  winnerId     String?
  matchType    GameFormat        // constructed | sealed | draft
  sealedConfig Json?
  draftConfig  Json?
  draftState   Json?
  playerDecks  Json?
  sealedPacks  Json?
  game         Json?
  lastTs       BigInt?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  actions      OnlineMatchAction[]

  @@index([status])
  @@index([createdAt])
}

model OnlineMatchAction {
  id        String             @id @default(cuid())
  matchId   String
  playerId  String
  timestamp BigInt
  patch     Json

  match OnlineMatchSession @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([timestamp])
}

model MatchResult {
  id           String     @id @default(cuid())
  matchId      String
  lobbyName    String?    // Store lobby name for titles
  winnerId     String?
  loserId      String?
  isDraw       Boolean    @default(false)
  format       GameFormat
  tournamentId String?
  players      Json       // Array of player info
  duration     Int?       // Match duration in seconds
  completedAt  DateTime   @default(now())

  winner       User?      @relation("MatchWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  loser        User?      @relation("MatchLoser", fields: [loserId], references: [id], onDelete: SetNull)

  @@index([winnerId])
  @@index([loserId])
  @@index([format])
  @@index([tournamentId])
  @@index([completedAt])
}

// Draft session models for tournament draft format
enum DraftStatus {
  waiting
  active
  completed
  cancelled
}

enum ParticipantStatus {
  waiting
  active
  completed
  disconnected
}

model DraftSession {
  id                String             @id @default(cuid())
  tournamentId      String
  status            DraftStatus        @default(waiting)
  packConfiguration Json               // Pack configuration for the draft
  settings          Json               // Draft settings (time limits, etc.)
  draftState        Json?              // Current draft state (packs, picks, etc.)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())

  tournament        Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  participants      DraftParticipant[]

  @@index([tournamentId])
  @@index([status])
}

model DraftParticipant {
  id              String            @id @default(cuid())
  draftSessionId  String
  playerId        String
  seatNumber      Int
  status          ParticipantStatus @default(waiting)
  pickData        Json?             // Player's picks and pack data
  deckData        Json?             // Final deck after draft
  joinedAt        DateTime          @default(now())

  draftSession    DraftSession      @relation(fields: [draftSessionId], references: [id], onDelete: Cascade)
  player          User              @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([draftSessionId, playerId])
  @@unique([draftSessionId, seatNumber])
  @@index([draftSessionId])
  @@index([playerId])
}

// WebAuthn passkey credentials per user
model PasskeyCredential {
  id                String   @id @default(cuid())
  userId            String
  credentialId      Bytes    @unique         // Raw credential ID bytes
  publicKey         Bytes                     // Raw public key bytes (COSE)
  counter           Int       @default(0)
  transports        String?                    // CSV of transports
  aaguid            String?                    // Authenticator AAGUID
  attestationType   String?                    // none, basic, etc.
  deviceType        String?                    // platform or cross-platform
  backedUp          Boolean?                   // authenticator backups supported
  createdAt         DateTime @default(now())
  lastUsedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Friendship {
  id           String   @id @default(cuid())
  ownerUserId  String
  targetUserId String
  createdAt    DateTime @default(now())

  owner  User @relation("FriendshipOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  target User @relation("FriendshipTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, targetUserId])
  @@index([ownerUserId])
  @@index([targetUserId])
}

// Tournament invitation system for private tournaments
enum InvitationStatus {
  pending
  accepted
  declined
  expired
}

model TournamentInvitation {
  id           String           @id @default(cuid())
  tournamentId String
  inviteeId    String           // User being invited
  inviterId    String?          // User who sent the invite (null if system-generated)
  status       InvitationStatus @default(pending)
  createdAt    DateTime         @default(now())
  respondedAt  DateTime?        // When invitation was accepted/declined
  expiresAt    DateTime?        // Optional expiration time

  tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  invitee      User             @relation(fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, inviteeId])
  @@index([tournamentId])
  @@index([inviteeId])
  @@index([status])
}

// T027: Audit logging for tournament broadcast events
model TournamentBroadcastEvent {
  id           String   @id @default(cuid())
  tournamentId String
  eventType    String   // PHASE_CHANGED, ROUND_STARTED, etc.
  payload      Json     // Complete event payload
  timestamp    DateTime @default(now())
  emittedBy    String?  // Server ID or process identifier
  roomTarget   String   // Socket.IO room (e.g., "tournament:xyz")

  @@index([tournamentId, timestamp(sort: Desc)])
  @@index([eventType])
}

// T028: Health monitoring for socket broadcast requests
model SocketBroadcastHealth {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  eventType    String   // Event being broadcast
  tournamentId String?  // Tournament ID if applicable
  targetUrl    String   // Full URL of broadcast endpoint
  success      Boolean  // Whether broadcast succeeded
  statusCode   Int?     // HTTP status code
  errorMessage String?  // Error message if failed
  retryCount   Int      @default(0) // Number of retries attempted
  latencyMs    Int      // Latency in milliseconds

  @@index([timestamp(sort: Desc)])
  @@index([success])
  @@index([eventType])
}

// Card evaluation storage for bot AI
model CardEvaluation {
  id                  Int      @id @default(autoincrement())
  cardId              Int      @unique
  card                Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  
  // Evaluation data
  category            String   // minion, spell, artifact, aura, site
  evaluationFunction  String   @db.Text
  priority            String   @db.Text
  synergies           Json     // Array of synergy tags
  antiSynergies       Json     // Array of anti-synergy tags
  situational         Boolean  @default(false)
  complexity          String   // simple, moderate, complex
  
  // Generation metadata
  generatedBy         String   // "llm" or "direct"
  model               String?  // e.g., "claude-3-5-sonnet-20241022"
  validationStatus    String   @default("pending") // pending, validated, failed
  validationError     String?  @db.Text
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([cardId])
  @@index([category])
  @@index([validationStatus])
  @@index([generatedBy])
}
