generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Set {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  releasedAt      DateTime?
  cardListCards   CardListCard[]    @relation("CardListCardSet")
  cardMeta        CardSetMetadata[]
  collectionCards CollectionCard[]  @relation("CollectionCardSet")
  cubeCards       CubeCard[]        @relation("CubeCardSet")
  deckCards       DeckCard[]        @relation("DeckCardSet")
  packConfig      PackConfig?
  variants        Variant[]

  @@index([name])
}

model Card {
  id                Int               @id @default(autoincrement())
  name              String
  elements          String?
  subTypes          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  evaluation        CardEvaluation?
  cardListCards     CardListCard[]
  meta              CardSetMetadata[]
  collectionCards   CollectionCard[]
  cubeCards         CubeCard[]
  championedByDecks Deck[]            @relation("DeckChampion")
  deckCards         DeckCard[]
  variants          Variant[]

  @@index([name])
}

model CardSetMetadata {
  id         Int     @id @default(autoincrement())
  cardId     Int
  setId      Int
  rarity     Rarity?
  type       String
  rulesText  String?
  cost       Int?
  attack     Int?
  defence    Int?
  life       Int?
  thresholds Json?
  card       Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  set        Set     @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([cardId, setId])
  @@index([setId, rarity])
}

model Variant {
  id              Int              @id @default(autoincrement())
  cardId          Int
  setId           Int
  slug            String           @unique
  finish          Finish
  product         String
  artist          String?
  flavorText      String?
  typeText        String?
  imageBasename   String?
  cardListCards   CardListCard[]   @relation("CardListCardVariant")
  collectionCards CollectionCard[] @relation("CollectionCardVariant")
  cubeCards       CubeCard[]       @relation("CubeCardVariant")
  deckCards       DeckCard[]       @relation("DeckCardVariant")
  card            Card             @relation(fields: [cardId], references: [id], onDelete: Cascade)
  set             Set              @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@index([setId])
  @@index([cardId])
  @@index([typeText])
}

model PackConfig {
  id                    Int     @id @default(autoincrement())
  setId                 Int     @unique
  ordinaryCount         Int
  exceptionalCount      Int
  eliteOrUniqueCount    Int
  uniqueChance          Float
  siteOrAvatarCount     Int     @default(0)
  foilChance            Float?
  foilUniqueWeight      Int     @default(1)
  foilEliteWeight       Int     @default(3)
  foilExceptionalWeight Int     @default(6)
  foilOrdinaryWeight    Int     @default(7)
  foilReplacesOrdinary  Boolean @default(true)
  isFixedPack           Boolean @default(false)
  set                   Set     @relation(fields: [setId], references: [id], onDelete: Cascade)
}

model Deck {
  id             String     @id @default(cuid())
  name           String
  format         String     @default("Constructed")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  userId         String
  isPublic       Boolean    @default(false)
  imported        Boolean    @default(false)
  curiosaSourceId String?    // Curiosa deck ID for sync functionality
  championCardId  Int?
  champion       Card?      @relation("DeckChampion", fields: [championCardId], references: [id])
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards          DeckCard[]

  @@index([userId])
  @@index([isPublic, createdAt])
}

model DeckCard {
  id        Int      @id @default(autoincrement())
  deckId    String
  cardId    Int
  setId     Int?
  variantId Int?
  zone      String
  count     Int
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  set       Set?     @relation("DeckCardSet", fields: [setId], references: [id])
  variant   Variant? @relation("DeckCardVariant", fields: [variantId], references: [id])

  @@index([deckId])
  @@index([cardId])
  @@index([variantId])
  @@index([deckId, zone])
}

model Cube {
  id          String     @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean    @default(false)
  imported    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards       CubeCard[]

  @@index([userId])
  @@index([isPublic, createdAt])
}

model CubeCard {
  id        Int      @id @default(autoincrement())
  cubeId    String
  cardId    Int
  setId     Int?
  variantId Int?
  count     Int
  zone      String   @default("main")
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cube      Cube     @relation(fields: [cubeId], references: [id], onDelete: Cascade)
  set       Set?     @relation("CubeCardSet", fields: [setId], references: [id])
  variant   Variant? @relation("CubeCardVariant", fields: [variantId], references: [id])

  @@index([cubeId])
  @@index([cardId])
}

model CollectionCard {
  id        Int      @id @default(autoincrement())
  userId    String
  cardId    Int
  setId     Int?
  variantId Int?
  finish    Finish   @default(Standard)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notes     String?
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  set       Set?     @relation("CollectionCardSet", fields: [setId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   Variant? @relation("CollectionCardVariant", fields: [variantId], references: [id])

  @@unique([userId, cardId, variantId, finish])
  @@index([userId])
  @@index([cardId])
  @@index([userId, setId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  isPro                   Boolean                  @default(false)
  stats                   String?
  presenceHidden          Boolean                  @default(false)
  shortId                 String?                  @unique
  colorBlindMode          Boolean                  @default(false)
  patronTier              String?
  selectedPlaymatRef      String?
  selectedAtlasRef        String?
  selectedSpellbookRef    String?
  showOpponentPlaymat     Boolean                  @default(true)
  cameraMode              String                   @default("topdown")
  showPlaymat             Boolean                  @default(true)
  showGrid                Boolean                  @default(false)
  soatcAutoDetect         Boolean                  @default(false)
  soatcUuid               String?
  discordId               String?                  @unique
  discordUsername         String?
  accounts                Account[]
  cardLists               CardList[]
  collectionCards         CollectionCard[]
  cubes                   Cube[]
  customCardbacks         CustomCardback[]
  customPlaymats          CustomPlaymat[]
  decks                   Deck[]
  draftParticipations     DraftParticipant[]
  friendshipsOwned        Friendship[]             @relation("FriendshipOwner")
  friendshipsTargeted     Friendship[]             @relation("FriendshipTarget")
  leaderboardEntries      LeaderboardEntry[]
  lostMatches             MatchResult[]            @relation("MatchLoser")
  wonMatches              MatchResult[]            @relation("MatchWinner")
  passkeys                PasskeyCredential[]
  standings               PlayerStanding[]
  sessions                Session[]
  soatcMatchesAsPlayer1   SoatcMatchResult[]       @relation("SoatcPlayer1")
  soatcMatchesAsPlayer2   SoatcMatchResult[]       @relation("SoatcPlayer2")
  createdTournaments      Tournament[]
  tournamentInvitations   TournamentInvitation[]
  tournamentRegistrations TournamentRegistration[]
  tournamentStatistics    TournamentStatistics[]   @relation("TournamentPlayerStats")
}

model CustomPlaymat {
  id        String   @id @default(cuid())
  userId    String
  name      String
  mimeType  String
  width     Int
  height    Int
  sizeBytes Int
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model CustomCardback {
  id              String   @id @default(cuid())
  userId          String
  name            String
  spellbookMime   String
  spellbookWidth  Int
  spellbookHeight Int
  spellbookSize   Int
  spellbookData   Bytes
  atlasMime       String
  atlasWidth      Int
  atlasHeight     Int
  atlasSize       Int
  atlasData       Bytes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model SoatcMatchResult {
  id             String     @id @default(cuid())
  matchId        String     @unique
  tournamentId   String
  tournamentName String
  player1Id      String
  player1SoatcId String
  player2Id      String
  player2SoatcId String
  winnerId       String?
  winnerSoatcId  String?
  isDraw         Boolean    @default(false)
  format         GameFormat
  resultJson     Json
  startedAt      DateTime
  completedAt    DateTime   @default(now())
  createdAt      DateTime   @default(now())
  player1        User       @relation("SoatcPlayer1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2        User       @relation("SoatcPlayer2", fields: [player2Id], references: [id], onDelete: Cascade)

  @@index([player1Id])
  @@index([player2Id])
  @@index([tournamentId])
  @@index([completedAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tournament {
  id            String                   @id @default(cuid())
  name          String
  creatorId     String
  format        TournamentFormat
  status        TournamentStatus         @default(registering)
  maxPlayers    Int
  settings      Json
  featureFlags  Json?
  startedAt     DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  completedAt   DateTime?
  isPrivate     Boolean                  @default(false)
  draftSessions DraftSession[]
  matches       Match[]
  standings     PlayerStanding[]
  creator       User                     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  invitations   TournamentInvitation[]
  registrations TournamentRegistration[]
  rounds        TournamentRound[]
  statistics    TournamentStatistics[]   @relation("TournamentStatistics")

  @@index([status])
  @@index([createdAt])
  @@index([creatorId])
  @@index([isPrivate])
}

model TournamentRegistration {
  id                String            @id @default(cuid())
  tournamentId      String
  playerId          String
  registeredAt      DateTime          @default(now())
  preparationStatus PreparationStatus @default(notStarted)
  deckSubmitted     Boolean           @default(false)
  preparationData   Json?
  seatMeta          Json?
  seatStatus        SeatStatus        @default(active)
  player            User              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournament        Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
}

model PlayerStanding {
  id                         String     @id @default(cuid())
  tournamentId               String
  playerId                   String
  displayName                String
  wins                       Int        @default(0)
  losses                     Int        @default(0)
  draws                      Int        @default(0)
  matchPoints                Int        @default(0)
  gameWinPercentage          Float      @default(0.0)
  opponentMatchWinPercentage Float      @default(0.0)
  isEliminated               Boolean    @default(false)
  currentMatchId             String?
  updatedAt                  DateTime   @updatedAt
  player                     User       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournament                 Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([matchPoints])
  @@index([tournamentId, matchPoints(sort: Desc)])
}

model TournamentRound {
  id           String      @id @default(cuid())
  tournamentId String
  roundNumber  Int
  status       RoundStatus @default(pending)
  startedAt    DateTime?
  completedAt  DateTime?
  pairingData  Json?
  matches      Match[]
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, roundNumber])
  @@index([tournamentId])
}

model Match {
  id           String           @id @default(cuid())
  tournamentId String?
  roundId      String?
  status       MatchStatus      @default(pending)
  players      Json
  results      Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  playerDecks  Json?
  round        TournamentRound? @relation(fields: [roundId], references: [id], onDelete: Cascade)
  tournament   Tournament?      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@index([roundId])
  @@index([status])
  @@index([tournamentId, status])
}

model TournamentStatistics {
  id           String     @id @default(cuid())
  tournamentId String
  playerId     String
  wins         Int        @default(0)
  losses       Int        @default(0)
  draws        Int        @default(0)
  matchPoints  Int        @default(0)
  tiebreakers  Json
  finalRanking Int?
  player       User       @relation("TournamentPlayerStats", fields: [playerId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation("TournamentStatistics", fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([matchPoints])
}

model LeaderboardEntry {
  id             String     @id @default(cuid())
  playerId       String
  displayName    String
  format         GameFormat
  timeFrame      TimeFrame
  wins           Int        @default(0)
  losses         Int        @default(0)
  draws          Int        @default(0)
  winRate        Float      @default(0.0)
  rating         Int        @default(1200)
  rank           Int        @default(0)
  tournamentWins Int        @default(0)
  lastActive     DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  player         User       @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, format, timeFrame])
  @@index([format, timeFrame, rating])
  @@index([format, timeFrame, winRate])
  @@index([rank])
}

model HumanCardStats {
  id        String     @id @default(cuid())
  cardId    Int
  format    GameFormat
  plays     Int        @default(0)
  wins      Int        @default(0)
  losses    Int        @default(0)
  draws     Int        @default(0)
  updatedAt DateTime   @updatedAt

  @@unique([cardId, format])
  @@index([cardId])
  @@index([format, plays])
}

model OnlineMatchSession {
  id           String              @id @default(cuid())
  lobbyId      String?
  lobbyName    String?
  playerIds    String[]
  status       OnlineMatchStatus   @default(waiting)
  seed         String
  turn         String?
  winnerId     String?
  matchType    GameFormat
  sealedConfig Json?
  draftConfig  Json?
  draftState   Json?
  playerDecks  Json?
  sealedPacks  Json?
  game         Json?
  lastTs       BigInt?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  actions      OnlineMatchAction[]

  @@index([status])
  @@index([createdAt])
}

model OnlineMatchAction {
  id        String             @id @default(cuid())
  matchId   String
  playerId  String
  timestamp BigInt
  patch     Json
  match     OnlineMatchSession @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([timestamp])
}

model MatchResult {
  id           String     @id @default(cuid())
  matchId      String
  lobbyName    String?
  winnerId     String?
  loserId      String?
  isDraw       Boolean    @default(false)
  format       GameFormat
  tournamentId String?
  players      Json
  duration     Int?
  completedAt  DateTime   @default(now())
  loser        User?      @relation("MatchLoser", fields: [loserId], references: [id])
  winner       User?      @relation("MatchWinner", fields: [winnerId], references: [id])

  @@index([winnerId])
  @@index([loserId])
  @@index([format])
  @@index([tournamentId])
  @@index([completedAt])
}

model DraftSession {
  id                String             @id @default(cuid())
  tournamentId      String
  status            DraftStatus        @default(waiting)
  packConfiguration Json
  settings          Json
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())
  draftState        Json?
  participants      DraftParticipant[]
  tournament        Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@index([status])
}

model DraftParticipant {
  id             String            @id @default(cuid())
  draftSessionId String
  playerId       String
  seatNumber     Int
  status         ParticipantStatus @default(waiting)
  pickData       Json?
  deckData       Json?
  joinedAt       DateTime          @default(now())
  draftSession   DraftSession      @relation(fields: [draftSessionId], references: [id], onDelete: Cascade)
  player         User              @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([draftSessionId, playerId])
  @@unique([draftSessionId, seatNumber])
  @@index([draftSessionId])
  @@index([playerId])
}

model PasskeyCredential {
  id              String    @id @default(cuid())
  userId          String
  credentialId    Bytes     @unique
  publicKey       Bytes
  counter         Int       @default(0)
  transports      String?
  aaguid          String?
  attestationType String?
  deviceType      String?
  backedUp        Boolean?
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Friendship {
  id           String   @id @default(cuid())
  ownerUserId  String
  targetUserId String
  createdAt    DateTime @default(now())
  owner        User     @relation("FriendshipOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  target       User     @relation("FriendshipTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, targetUserId])
  @@index([ownerUserId])
  @@index([targetUserId])
}

model TournamentInvitation {
  id           String           @id @default(cuid())
  tournamentId String
  inviteeId    String
  inviterId    String?
  status       InvitationStatus @default(pending)
  createdAt    DateTime         @default(now())
  respondedAt  DateTime?
  expiresAt    DateTime?
  invitee      User             @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
  tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, inviteeId])
  @@index([tournamentId])
  @@index([inviteeId])
  @@index([status])
}

model TournamentBroadcastEvent {
  id           String   @id @default(cuid())
  tournamentId String
  eventType    String
  payload      Json
  timestamp    DateTime @default(now())
  emittedBy    String?
  roomTarget   String

  @@index([tournamentId, timestamp(sort: Desc)])
  @@index([eventType])
}

model SocketBroadcastHealth {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  eventType    String
  tournamentId String?
  targetUrl    String
  success      Boolean
  statusCode   Int?
  errorMessage String?
  retryCount   Int      @default(0)
  latencyMs    Int

  @@index([timestamp(sort: Desc)])
  @@index([success])
  @@index([eventType])
}

model CardEvaluation {
  id                 Int      @id @default(autoincrement())
  cardId             Int      @unique
  category           String
  evaluationFunction String
  priority           String
  synergies          Json
  antiSynergies      Json
  situational        Boolean  @default(false)
  complexity         String
  generatedBy        String
  model              String?
  validationStatus   String   @default("pending")
  validationError    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  card               Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([category])
  @@index([validationStatus])
  @@index([generatedBy])
}

model CodexEntry {
  id        Int      @id @default(autoincrement())
  title     String   @unique
  content   String
  cardRefs  String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
}

model CardList {
  id          String         @id @default(cuid())
  name        String
  description String?
  userId      String
  isPublic    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards       CardListCard[]

  @@index([userId])
  @@index([isPublic, createdAt])
}

model CardListCard {
  id        Int      @id @default(autoincrement())
  listId    String
  cardId    Int
  setId     Int?
  variantId Int?
  finish    Finish   @default(Standard)
  quantity  Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  list      CardList @relation(fields: [listId], references: [id], onDelete: Cascade)
  set       Set?     @relation("CardListCardSet", fields: [setId], references: [id])
  variant   Variant? @relation("CardListCardVariant", fields: [variantId], references: [id])

  @@unique([listId, cardId, variantId, finish])
  @@index([listId])
  @@index([cardId])
}

enum Rarity {
  Ordinary
  Exceptional
  Elite
  Unique
}

enum Finish {
  Standard
  Foil
  Rainbow
}

enum TournamentFormat {
  sealed
  draft
  constructed
}

enum TournamentStatus {
  registering
  preparing
  active
  completed
  cancelled
}

enum PreparationStatus {
  notStarted
  inProgress
  completed
}

enum SeatStatus {
  active
  vacant
}

enum RoundStatus {
  pending
  active
  completed
}

enum MatchStatus {
  pending
  active
  completed
  cancelled
}

enum GameFormat {
  constructed
  sealed
  draft
}

enum TimeFrame {
  all_time
  monthly
  weekly
}

enum OnlineMatchStatus {
  waiting
  deck_construction
  in_progress
  ended
  completed
  cancelled
}

enum DraftStatus {
  waiting
  active
  completed
  cancelled
}

enum ParticipantStatus {
  waiting
  active
  completed
  disconnected
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
}

model DiscordLinkToken {
  id          String   @id @default(cuid())
  token       String   @unique
  discordId   String
  discordTag  String
  guildId     String?
  expiresAt   DateTime
  usedAt      DateTime?
  userId      String?
  createdAt   DateTime @default(now())

  @@index([token])
  @@index([discordId])
  @@index([expiresAt])
}

model DiscordChallenge {
  id            String                 @id @default(cuid())
  challengerId  String
  challengeeId  String
  format        GameFormat             @default(constructed)
  guildId       String?
  channelId     String?
  status        DiscordChallengeStatus @default(pending)
  matchId       String?
  expiresAt     DateTime
  createdAt     DateTime               @default(now())
  respondedAt   DateTime?

  @@index([challengerId])
  @@index([challengeeId])
  @@index([status])
  @@index([expiresAt])
}

enum DiscordChallengeStatus {
  pending
  accepted
  declined
  expired
}
